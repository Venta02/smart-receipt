# Application
APP_NAME=smart-receipt
APP_ENV=development
LOG_LEVEL=INFO
API_HOST=0.0.0.0
API_PORT=8000

# OCR Engine
OCR_LANG=en
OCR_USE_GPU=false
OCR_DET_MODEL_DIR=
OCR_REC_MODEL_DIR=
OCR_CLS_MODEL_DIR=

# Image Processing
MAX_IMAGE_SIZE_MB=10
MIN_IMAGE_WIDTH=400
MIN_IMAGE_HEIGHT=400
BLUR_THRESHOLD=100.0

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
CACHE_TTL_SECONDS=3600

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60

# Monitoring
ENABLE_METRICS=true

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2
